# Docker Compose shared settings
POSTGRES_IMAGE=postgres:16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=blog
POSTGRES_PORT=5432

SERVER_PORT=8080
PPROF_PORT=6060
CLIENT_PORT=5173

# App settings for server container
DATABASE_URL=postgres://postgres:postgres@postgres:5432/blog?sslmode=disable
DATABASE_URL_LOCAL=postgres://postgres:postgres@localhost:5432/blog?sslmode=disable
JWT_SECRET=change-me-in-production
CLIENT_URL=http://localhost:5173
SERVER_ADDR=:8080
PPROF_ADDR=127.0.0.1:6060
ENABLE_PPROF=false

# Frontend build-time API URL
VITE_API_BASE_URL=http://localhost:8080/api
