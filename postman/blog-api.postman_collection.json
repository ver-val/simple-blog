    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"asdf.asdf@example.com\",\n  \"password\": \"Asdf@1234\",\n  \"displayName\": \"asdf.asdf\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {", 
                  "  pm.response.to.have.status(201);", 
                  "});", 
                  "var data = pm.response.json();", 
                  "if (data.token) pm.environment.set('token', data.token);", 
                  "if (data.user && data.user.id) pm.environment.set('userId', String(data.user.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
