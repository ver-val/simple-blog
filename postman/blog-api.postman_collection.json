                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('get profile status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.test('get profile returns current user', function () {",
                  "  pm.expect(String(data.id)).to.eql(pm.environment.get('userId'));",
