        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"AQA\",\n  \"lastName\": \"User\",\n  \"age\": 25,\n  \"gender\": \"Female\",\n  \"address\": \"QA Street 1\",\n  \"website\": \"https://example.com\",\n  \"bio\": \"updated by API test\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/profile/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "profile",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('update profile status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.test('profile fields are updated', function () {",
                  "  pm.expect(data.firstName).to.eql('AQA');",
                  "  pm.expect(data.lastName).to.eql('User');",
                  "  pm.expect(data.age).to.eql(25);",
                  "  pm.expect(data.address).to.eql('QA Street 1');",
                  "});"
                ]
              }
            }
          ]
        }
