  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  var runId = String(Date.now());",
          "  pm.collectionVariables.set('runId', runId);",
          "  pm.collectionVariables.set('email', 'aqa+' + runId + '@example.com');",
          "  pm.collectionVariables.set('displayName', 'aqa_' + runId);",
          "  pm.collectionVariables.set('password', 'Asdf@1234');",
          "  pm.collectionVariables.set('newPassword', 'Qwer@1234');",
          "  pm.collectionVariables.set('postTitle', 'API post ' + runId);",
          "  pm.collectionVariables.set('postDescription', 'API description ' + runId);",
          "  pm.collectionVariables.set('postBody', 'API body ' + runId);",
          "  pm.collectionVariables.set('commentName', 'aqa');",
          "  pm.collectionVariables.set('commentMessage', 'comment ' + runId);",
          "  pm.environment.set('token', '');",
          "  pm.environment.set('postId', '');",
          "  pm.environment.set('resetToken', '');",
          "  pm.environment.set('userId', '');",
          "}",
          "pm.variables.set('email', pm.collectionVariables.get('email'));",
          "pm.variables.set('displayName', pm.collectionVariables.get('displayName'));",
          "pm.variables.set('password', pm.collectionVariables.get('password'));",
          "pm.variables.set('newPassword', pm.collectionVariables.get('newPassword'));",
          "pm.variables.set('postTitle', pm.collectionVariables.get('postTitle'));",
          "pm.variables.set('postDescription', pm.collectionVariables.get('postDescription'));",
          "pm.variables.set('postBody', pm.collectionVariables.get('postBody'));",
          "pm.variables.set('commentName', pm.collectionVariables.get('commentName'));",
          "pm.variables.set('commentMessage', pm.collectionVariables.get('commentMessage'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health status is 200', function () { pm.response.to.have.status(200); });",
              "var data = pm.response.json();",
              "pm.test('health payload contains ok status', function () { pm.expect(data.status).to.eql('ok'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"displayName\": \"{{displayName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register status is 201', function () { pm.response.to.have.status(201); });",
                  "var data = pm.response.json();",
                  "pm.test('register returns token and user', function () {",
                  "  pm.expect(data.token).to.be.a('string').and.not.empty;",
                  "  pm.expect(data.user.id).to.be.a('number');",
                  "  pm.expect(data.user.email).to.eql(pm.collectionVariables.get('email'));",
                  "  pm.expect(data.user.displayName).to.eql(pm.collectionVariables.get('displayName'));",
                  "});",
                  "pm.environment.set('token', data.token);",
                  "pm.environment.set('userId', String(data.user.id));"
                ]
              }
            }
          ]
        },
